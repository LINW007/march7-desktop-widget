{
  "version": "1.0",
  "description": "AI 高频用语黑名单 — 写网文时绝对避免的词汇和句式。以千字为单位统计命中次数，通过标准 <3次/千字。",
  "categories": {
    "强调副词": [
      "非常", "极其", "异常", "十分", "格外", "特别", "尤为",
      "无比", "绝顶", "极度", "万分", "惊人地", "不可思议地"
    ],
    "逻辑连接词": [
      "不仅如此", "更重要的是", "值得一提的是", "显而易见",
      "毋庸置疑", "众所周知", "总而言之", "综上所述",
      "归根结底", "从某种意义来说", "不可否认"
    ],
    "统计型措辞": [
      "在一定程度上", "在某种程度上", "相对而言",
      "大概率", "绝大多数", "部分地", "整体来看"
    ],
    "AI 式总结": [
      "总之", "这样一来", "由此可见", "这也意味着",
      "可以说", "不得不承认", "事实证明"
    ],
    "空洞强调": [
      "毫无疑问", "显然", "明显", "自然而然",
      "理所应当", "势必", "注定"
    ],
    "过度递进": [
      "不仅...而且...", "不但...甚至...",
      "既...又...还...", "一方面...另一方面..."
    ],
    "模板开场": [
      "随着", "伴随着", "当...的时候",
      "在...之下", "经过", "通过"
    ],
    "机械感叹": [
      "多么...啊", "真是...", "实在太..."
    ]
  },
  "sentence_patterns_blacklist": [
    {
      "pattern": "三段式论证",
      "description": "首先...其次...最后...",
      "severity": "high"
    },
    {
      "pattern": "二元对立",
      "description": "一边是...另一边是...",
      "severity": "high"
    },
    {
      "pattern": "递进堆砌",
      "description": "不仅...而且...甚至...",
      "severity": "high"
    },
    {
      "pattern": "排比开头",
      "description": "连续3句以上相同主语开头",
      "severity": "medium"
    },
    {
      "pattern": "因果链过长",
      "description": "因为...所以...因此...于是...",
      "severity": "medium"
    },
    {
      "pattern": "AI 总结句",
      "description": "总之/综上所述/归根结底",
      "severity": "medium"
    }
  ],
  "per_1000_chars_threshold": {
    "emphasis_adverbs": 2,
    "logical_connectors": 2,
    "hollow_emphasis": 1,
    "ai_summary": 0,
    "mechanical_exclamation": 1,
    "total_blacklist_hits": 3
  }
}
