{
  "version": "1.0",
  "source": "手动设定 + 将在写作中学习调整",
  "parameters": {
    "sentence": {
      "avg_length": { "value": 22, "range": [10, 30], "unit": "字" },
      "length_variance": { "value": "high" },
      "max_consecutive_same_length": 4
    },
    "composition": {
      "dialogue_ratio": { "value": 0.28, "range": [0.20, 0.35] },
      "description_ratio": { "value": 0.40, "range": [0.35, 0.50] },
      "narration_ratio": { "value": 0.22, "range": [0.15, 0.25] }
    },
    "paragraph": {
      "avg_length": { "value": 45, "range": [25, 70], "unit": "字" },
      "single_sentence_paragraph_ratio": { "value": 0.35, "range": [0.25, 0.45] },
      "max_paragraph_length": { "value": 120, "unit": "字" }
    },
    "dialogue": {
      "speech_pattern_consistency": { "value": "strict" },
      "subtext_requirement": { "value": true },
      "max_monologue_length": { "value": 80, "unit": "字" }
    },
    "rhetoric": {
      "preferred": ["白描", "比喻", "通感"],
      "avoid": ["排比", "对偶"],
      "metaphor_density": { "value": 4, "range": [2, 6], "unit": "次/千字" }
    },
    "perspective": {
      "type": "third_person_limited",
      "head_hopping": false
    },
    "idiom_usage": {
      "max_per_500_chars": 2,
      "consecutive_forbidden": true,
      "max_per_paragraph": 1
    },
    "punctuation_style": {
      "ellipsis_max_per_2000": 3,
      "exclamation_max_per_2000": 5,
      "dash_max_per_2000": 3
    }
  }
}
